import SwiftUI
import AuthenticationServices

struct ContentView: View {
    @Environment(\.colorScheme) var colorScheme

    @State private var offset: CGFloat = 0

    var exercises = ["Sudoku", "Rompecabezas", "Juegos de memoria", "Pensamiento lateral", "Rompecabezas numéricos"]
    var exerciseIcons = ["puzzlepiece", "gamecontroller", "brain", "lightbulb", "number.square"]
    var cardColors: [Gradient] = [
        Gradient(colors: [.blue.opacity(0.7), .blue]),
        Gradient(colors: [.green.opacity(0.7), .green]),
        Gradient(colors: [.orange.opacity(0.7), .orange]),
        Gradient(colors: [.yellow.opacity(0.7), .yellow]),
        Gradient(colors: [.red.opacity(0.7), .red])
    ]

    var body: some View {
        NavigationView {
            VStack(alignment: .leading, spacing: 20) {
                HStack {
                    Text("Desafíos")
                        .font(.largeTitle)
                        .fontWeight(.bold)
                        .foregroundColor(colorScheme == .dark ? .white : .primary)
                }
                .padding(.top, 50)
                .padding(.horizontal)

                Text("¡Bienvenido a desafíos! Disfruta de tres modos de juego diferentes con miles de preguntas de cultura general, usa todas tus habilidades.")
                    .multilineTextAlignment(.leading)
                    .padding(EdgeInsets(top: 0, leading: 20, bottom: 0, trailing: 20))
                    .foregroundColor(colorScheme == .dark ? .white : .primary)

                ScrollView(.horizontal, showsIndicators: false) {
                    HStack(spacing: 10) {
                        ForEach(0..<exercises.count, id: \.self) { index in
                            CardView(title: exercises[index], iconName: exerciseIcons[index], gradient: cardColors[index])
                                .frame(width: 150)
                        }
                    }
                    .padding(.horizontal, 20)
                    .offset(x: offset)
                    .gesture(
                        DragGesture()
                            .onChanged { value in
                                withAnimation {
                                    offset += value.translation.width
                                }
                            }
                    )
                }

                Text("En tu aventura podrás jugar dentro de los 3 pilares más importantes, y disfrutar de una experiencia inolvidable, fluida y lag-free.")
                    .multilineTextAlignment(.leading)
                    .padding(EdgeInsets(top: 0, leading: 20, bottom: 20, trailing: 20))
                    .foregroundColor(colorScheme == .dark ? .white : .primary)

                HStack {
                    Image(systemName: "map")
                        .resizable()
                        .aspectRatio(contentMode: .fit)
                        .frame(width: 30, height: 30)
                        .foregroundColor(Color.blue)

                    Text("Clasico. Avanza por diferentes tipos de niveles y progresa todo lo que puedas.")
                        .multilineTextAlignment(.leading)
                        .padding(.leading, 8)
                }
                .padding(EdgeInsets(top: 0, leading: 20, bottom: 0, trailing: 20))
                .foregroundColor(colorScheme == .dark ? .white : .primary)

                HStack {
                    Image(systemName: "shareplay")
                        .resizable()
                        .aspectRatio(contentMode: .fit)
                        .frame(width: 30, height: 30)
                        .foregroundColor(Color.green)

                    Text("Shareplay. Enfrentate a tú familia y amigos para ver quién se lleva la victoria.")
                        .multilineTextAlignment(.leading)
                        .padding(.leading, 8)
                }
                .padding(EdgeInsets(top: 0, leading: 20, bottom: 0, trailing: 20))
                .foregroundColor(colorScheme == .dark ? .white : .primary)

                HStack {
                    Image(systemName: "flag.checkered.2.crossed")
                        .resizable()
                        .aspectRatio(contentMode: .fit)
                        .frame(width: 30, height: 30)
                        .foregroundColor(Color.orange)

                    Text("Competitivo. Lucha contra todos los jugadores del mundo en el ranking.")
                        .multilineTextAlignment(.leading)
                        .padding(.leading, 8)
                }
                .padding(EdgeInsets(top: 0, leading: 20, bottom: 0, trailing: 20))
                .foregroundColor(colorScheme == .dark ? .white : .primary)

                Spacer()

                NavigationLink(destination: SecondView()) {
                Text("¡Entra y regístrate!")
                .padding()
                .frame(maxWidth: .infinity)
                .background(LinearGradient(gradient: Gradient(colors: [Color.blue.opacity(1.2), Color.blue.opacity(0.3)]), startPoint: .leading, endPoint: .trailing))
                .foregroundColor(.white)
                .cornerRadius(9)
                .padding(.horizontal, 0)
                .padding(.bottom, 0)
                }


                Text("App de desafíos. Versión actual: Release 0.3")
                    .font(.footnote)
                    .foregroundColor(.gray)
                    .fontWeight(.bold)
                    .multilineTextAlignment(.center)
                    .padding(.bottom, 20)
                    .frame(maxWidth: .infinity)
            }
            .padding()
            .background(colorScheme == .dark ? Color.black : Color.white)
            .edgesIgnoringSafeArea(.all)
            .navigationBarBackButtonHidden(true)
        }
    }
}

struct CardView: View {
    var title: String
    var iconName: String
    var gradient: Gradient
    
    var body: some View {
        VStack {
            ZStack {
                Rectangle()
                    .fill(LinearGradient(gradient: gradient, startPoint: .topLeading, endPoint: .bottomTrailing))
                    .frame(width: 150, height: 150)
                    .cornerRadius(9)
                
                VStack {
                    Image(systemName: iconName)
                        .resizable()
                        .aspectRatio(contentMode: .fit)
                        .frame(width: 50, height: 40)
                        .padding(.top, 0)
                        .foregroundColor(.white)

                    Text(title)
                        .foregroundColor(.white)
                        .font(.headline)
                        .multilineTextAlignment(.center)
                        .padding(.horizontal, 0)
                        .frame(maxWidth: .infinity)

                }
            }
        }
        .padding(.top, 0)
    }
}

struct ContentView_Previews: PreviewProvider {
    static var previews: some View {
        ContentView()
    }
